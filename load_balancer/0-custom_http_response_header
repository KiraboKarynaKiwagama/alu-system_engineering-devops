#!/usr/bin/env bash
# shellcheck disable=SC2154
# Configures Nginx to add a custom X-Served-By header with the hostname.

# Update package list and install nginx if not already installed
sudo apt-get update -y
sudo apt-get install -y nginx

# Get this machine's hostname 
HOSTNAME=$(hostname)

# Path to the default site configuration
CONFIG_FILE="/etc/nginx/sites-available/default"

# Check if the custom header line exists inside the server block
if grep -A 20 "server {" "$CONFIG_FILE" | grep -q "add_header X-Served-By"; then
    # The header exists; check if it contains the correct hostname
    if ! grep "add_header X-Served-By ${HOSTNAME};" "$CONFIG_FILE" > /dev/null; then
        # Update the existing header line with the correct hostname
        sudo sed -i "/add_header X-Served-By/c\    add_header X-Served-By ${HOSTNAME};" "$CONFIG_FILE"
    fi
else
    # Insert the add_header directive inside the server block
    sudo sed -i "/server {/a \\\tadd_header X-Served-By ${HOSTNAME};" "$CONFIG_FILE"
fi

# Test nginx configuration for syntax errors
sudo nginx -t && sudo service nginx restart
